# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=pos-events
KAFKA_DLQ_TOPIC=pos-events-dlq
KAFKA_DERIVED_TOPIC=pos-derived-events

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API
API_HOST=0.0.0.0
API_PORT=8000

# JWT Authentication
JWT_SECRET=DummySecret
JWT_REFRESH_SECRET=DummySecret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Generator
GENERATOR_MODE=burst
GENERATOR_TRANSACTION_COUNT=8

# Consumer config refresh interval (seconds)
CONFIG_REFRESH_INTERVAL=5

# Plugin HTTP target (mock)
HTTP_PLUGIN_URL=http://api:8000/webhook/mock
