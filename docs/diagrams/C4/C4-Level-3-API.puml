@startuml C4-Level-3-API
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title C4 Level 3 - Component Diagram\nAPI Container

Container_Boundary(api, "API (FastAPI :8000)") {
    Component(auth, "Auth", "FastAPI router", "Login, refresh token, /me; validates credentials; issues JWT; publishes employee.login")
    Component(plugin_routes, "Plugin Routes", "FastAPI router", "GET/PUT /plugins; list and update plugin config")
    Component(event_routes, "Event Routes", "FastAPI router", "GET/DELETE /events; list and clear event_log")
    Component(pos_routes, "POS Terminal Routes", "FastAPI router", "POST /pos/transaction/*; build and publish POS events")
    Component(webhook, "Webhook Sink", "FastAPI endpoint", "POST /webhook/mock; receives HTTP Call plugin payloads")
    Component(database, "Database Adapter", "psycopg2", "get_connection; fetch_all_plugins; update_plugin; fetch_event_log; delete_all_events")
    Component(middleware, "Auth Middlew are", "FastAPI Depends", "get_current_user (JWT); require_role(ADMIN)")
}

ContainerDb_Ext(postgres, "Database", "PostgreSQL", "plugins, event_log, employees, refresh_tokens")
ContainerQueue_Ext(kafka, "Message Broker", "Kafka", "pos-events")

Rel(auth, database, "Query employees, roles; insert refresh_tokens", "")
Rel(auth, kafka, "Publish employee.login", "Kafka producer")
Rel(auth, middleware, "Uses for /me", "")
Rel(plugin_routes, database, "CRUD plugins", "")
Rel(plugin_routes, middleware, "get_current_user, require_role", "")
Rel(event_routes, database, "Read/delete event_log", "")
Rel(event_routes, middleware, "get_current_user, require_role", "")
Rel(pos_routes, kafka, "Publish POS events", "Kafka producer")
Rel(pos_routes, middleware, "get_current_user", "")

@enduml
